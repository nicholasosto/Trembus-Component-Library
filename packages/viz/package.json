{
  "name": "@trembus/viz",
  "version": "0.1.0",
  "description": "Trembus Tier-2 node-link visualizations (Tree, Lineage) — the same 3-jobs contract spine as @trembus/ui's Tier-1 viz, with a layout engine (d3-hierarchy).",
  "type": "module",
  "license": "MIT",
  "author": "Nicholas Osto",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicholasosto/Trembus-Component-Library.git",
    "directory": "packages/viz"
  },
  "homepage": "https://github.com/nicholasosto/Trembus-Component-Library/tree/main/packages/viz#readme",
  "bugs": "https://github.com/nicholasosto/Trembus-Component-Library/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "check:contracts": "tsx ../../scripts/check-contracts.ts viz",
    "verify:exports": "rm -rf .pack && pnpm pack --pack-destination .pack >/dev/null && publint .pack/*.tgz && attw .pack/*.tgz --profile esm-only --exclude-entrypoints ./styles.css && rm -rf .pack",
    "validate": "pnpm lint && pnpm typecheck && pnpm check:contracts && pnpm test && pnpm build && pnpm verify:exports",
    "prepublishOnly": "pnpm build && pnpm verify:exports"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@trembus/tokens": "workspace:^",
    "d3-hierarchy": "^3.1.2"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^26.0.0",
    "publint": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
