{
  "name": "@trembus/ui",
  "version": "0.8.3",
  "description": "Trembus React component library — first-principles UX, claude.ai-clean light + Trembus dark themes.",
  "type": "module",
  "keywords": [
    "react",
    "react-components",
    "component-library",
    "design-system",
    "ui-components",
    "data-visualization",
    "decision-map",
    "swimlane",
    "accessibility",
    "a11y",
    "design-tokens",
    "css-variables",
    "typescript",
    "trembus"
  ],
  "license": "MIT",
  "author": "Nicholas Osto",
  "private": false,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicholasosto/Trembus-Component-Library.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/nicholasosto/Trembus-Component-Library/tree/main/packages/ui#readme",
  "bugs": "https://github.com/nicholasosto/Trembus-Component-Library/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "check:contracts": "tsx ../../scripts/check-contracts.ts ui",
    "verify:exports": "node ../../scripts/verify-exports.mjs --exclude-entrypoints ./styles.css",
    "validate": "pnpm lint && pnpm typecheck && pnpm check:contracts && pnpm test && pnpm build && pnpm verify:exports",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@trembus/icons": "workspace:^",
    "@trembus/tokens": "workspace:^"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@eslint/js": "^9.0.0",
    "@storybook/addon-a11y": "^9.0.0",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/addon-vitest": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/browser": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^9.0.0",
    "globals": "^16.0.0",
    "jest-axe": "^9.0.0",
    "jsdom": "^26.0.0",
    "playwright": "^1.48.0",
    "prettier": "^3.4.0",
    "publint": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
