{
  "name": "@trembus/icons",
  "version": "0.2.0",
  "description": "The Trembus glyph set — hand-authored, normalized 24×24 inline-SVG icons (node/file-type marks + UI affordances) shared by @trembus/ui and @trembus/viz. Pure React components, no stylesheet: monochrome glyphs paint currentColor (the consumer tints via a token); brand marks (TS, JS, …) carry their own color.",
  "type": "module",
  "keywords": [
    "react",
    "icons",
    "svg",
    "glyphs",
    "currentcolor",
    "tree-shakeable",
    "file-type-icons",
    "design-system",
    "trembus"
  ],
  "license": "MIT",
  "author": "Nicholas Osto",
  "private": false,
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nicholasosto/Trembus-Component-Library.git",
    "directory": "packages/icons"
  },
  "homepage": "https://github.com/nicholasosto/Trembus-Component-Library/tree/main/packages/icons#readme",
  "bugs": "https://github.com/nicholasosto/Trembus-Component-Library/issues",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --project unit",
    "test:watch": "vitest --project unit",
    "verify:exports": "node ../../scripts/verify-exports.mjs",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm verify:exports",
    "prepublishOnly": "pnpm build"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^26.0.0",
    "publint": "^0.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.3.0",
    "vitest": "^3.0.0"
  }
}
