{
  "name": "trembus-component-library",
  "version": "0.0.0",
  "description": "Trembus component library workspace — @trembus/tokens · @trembus/ui · @trembus/viz · @trembus/game-viz.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build:storybook": "storybook build -o storybook-static",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck:root": "tsc --noEmit -p tsconfig.json",
    "typecheck": "pnpm typecheck:root && pnpm -r typecheck",
    "check:contracts": "tsx scripts/check-contracts.ts",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:stories": "vitest run --project storybook",
    "verify:exports": "pnpm -r verify:exports",
    "validate": "pnpm -r build && pnpm lint && pnpm typecheck && pnpm check:contracts && pnpm -r test && pnpm -r verify:exports && pnpm build:storybook",
    "demos:check": "pnpm --filter @trembus/viz... --filter @trembus/game-viz... run build && pnpm --filter \"./demos/*\" run tc && pnpm --filter \"./demos/*\" run build:site",
    "templates:check": "pnpm --filter @trembus/ui... run build && pnpm --filter @trembus-templates/pages tc"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@storybook/addon-a11y": "^9.0.0",
    "@storybook/addon-docs": "^9.0.0",
    "@storybook/addon-vitest": "^9.0.0",
    "@storybook/react-vite": "^9.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/browser": "^3.0.0",
    "eslint": "^9.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-storybook": "^9.0.0",
    "globals": "^16.0.0",
    "playwright": "^1.48.0",
    "prettier": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
